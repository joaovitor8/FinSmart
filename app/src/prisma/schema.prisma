generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Usuário do sistema
model User {
  id              String    @id @default(uuid())
  email           String    @unique
  name            String?
  passwordHash    String
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())

  // Relações
  monthlyFees             MonthlyFees[]
  goals                   Goal[]
  transactions            Transaction[]
  categories              Category[]
  budgets                 Budget[]
  sessions                Session[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
}

// Token de verificação de email. Armazenamos só o hash — o token em si
// (que vai no link do email) nunca toca o DB. Se vazar o DB, ninguém
// consegue reusar os tokens.
model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Token de reset de senha. Mesmo padrão: armazenamos só o hash.
model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Sessão de login. O JWT carrega o ID dessa sessão. Permite revogar sem
// invalidar todas as sessões do usuário (ex: encerrar só a do celular roubado).
model Session {
  id         String    @id @default(uuid())
  userId     String
  userAgent  String?   @db.VarChar(500)
  ip         String?   @db.VarChar(64)
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime  @default(now())
  revokedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([revokedAt])
}

// Categoria criada pelo usuário (Alimentação, Transporte, Salário, etc.)
enum CategoryType {
  INCOME
  EXPENSE
  BOTH
}

model Category {
  id        String       @id @default(uuid())
  userId    String
  name      String
  icon      String       // identificador do ícone (ver lib/constants.ts)
  color     String       // emerald, blue, amber, purple, rose, sky, orange, teal, zinc
  type      CategoryType @default(EXPENSE)
  createdAt DateTime     @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  monthlyFees  MonthlyFees[]
  budget       Budget?

  @@unique([userId, name])
  @@index([userId])
}

// Limite mensal de gasto por categoria (1 por categoria, vale para o mês corrente)
model Budget {
  id         String   @id @default(uuid())
  userId     String
  categoryId String   @unique
  amount     Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Mensalidades / contas fixas / assinaturas
model MonthlyFees {
  id         String   @id @default(uuid())
  userId     String
  name       String
  amount     Decimal  @db.Decimal(12, 2)
  categoryId String
  frequency  String   // "Mensal" | "Anual"
  date       DateTime

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([categoryId])
}

// Metas de economia
model Goal {
  id        String   @id @default(uuid())
  userId    String
  name      String
  target    Decimal  @db.Decimal(12, 2)
  current   Decimal  @default(0) @db.Decimal(12, 2)
  icon      String   @default("target")
  color     String   @default("emerald")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Lançamentos (entrada/saída pontual)
enum TransactionType {
  INCOME
  EXPENSE
}

model Transaction {
  id          String          @id @default(uuid())
  userId      String
  type        TransactionType
  amount      Decimal         @db.Decimal(12, 2)
  description String
  categoryId  String
  date        DateTime
  createdAt   DateTime        @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([userId, date])
  @@index([categoryId])
}

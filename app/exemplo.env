# Copie esse arquivo para `.env` e preencha com seus valores.

# URL do banco PostgreSQL
# Exemplo local: postgresql://postgres:postgres@localhost:5432/finsmart
DATABASE_URL=""

# Segredo do JWT (use algo longo e aleatório, ex: `openssl rand -base64 48`)
JWT_SECRET=""

# Chave da Anthropic API para o Mentor IA (https://console.anthropic.com/)
ANTHROPIC_API_KEY=""

# Upstash Redis para rate-limit distribuído (https://console.upstash.com/)
# Em produção é OBRIGATÓRIO. Em dev, sem essas envs, cai pro fallback em memória.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Resend para envio de emails (https://resend.com/api-keys)
# Em dev, EMAIL_FROM pode ser "onboarding@resend.dev" (só envia pro email da conta Resend).
# Em prod, configure um domínio verificado no painel da Resend.
RESEND_API_KEY=""
EMAIL_FROM="FinSmart <onboarding@resend.dev>"
APP_URL="http://localhost:3000"

